{
  "name": "@airarena/arc-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Isolated Arc Testnet backend, middleman, and MCP services for AIR Arena",
  "type": "module",
  "engines": {
    "node": ">=22.12 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests",
    "test:market-spec": "vitest run tests/market-spec.test.ts",
    "test:coverage": "vitest run tests --coverage",
    "start": "node dist/entrypoint.js",
    "dev:api": "SERVICE_ROLE=api tsx src/entrypoint.ts",
    "dev:middleman": "SERVICE_ROLE=middleman tsx src/entrypoint.ts",
    "dev:mcp": "SERVICE_ROLE=mcp tsx src/entrypoint.ts",
    "db:migrate": "tsx src/cli/migrate.ts",
    "batch:replay": "tsx src/cli/replay-batch.ts",
    "market-spec:vector": "tsx src/cli/print-market-spec-vector.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.3.0",
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "pino": "^9.14.0",
    "prom-client": "^15.1.3",
    "viem": "^2.38.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/pg": "^8.15.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.7",
    "fast-check": "^4.9.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
